# birdbench — 各家多模态 API key（复制成 .env 填入；.env 不进 git）
# 只填你要测的家即可；LiteLLM 按前缀路由到对应端点。

OPENAI_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=                 # Grok
DASHSCOPE_API_KEY=           # 阿里 Qwen-VL
ARK_API_KEY=                 # 字节豆包（火山方舟）；model 用 ep-... 或模型名
MOONSHOT_API_KEY=            # Kimi（视觉仅 base64）
ZAI_API_KEY=                 # 智谱 GLM-4V/4.6V
LONGCAT_API_KEY=             # 美团 LongCat（实验位，openai 兼容 + api_base）

# 可选：评测并发/预算护栏
BIRDBENCH_MAX_CONCURRENCY=8
BIRDBENCH_SPEND_CAP_USD=
