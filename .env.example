# birdbench — 各家多模态 API key（复制成 .env 填入；.env 不进 git）
# 只填你要测的家即可；LiteLLM 按前缀路由到对应端点。
# 注意：key 是 per-provider，**一把 key 可测该家多个模型**（如一把 DASHSCOPE_API_KEY 测 qwen3-vl-plus/flash）。
# 具体测哪些模型在 configs/models.json 配置。前端 BIRDBENCH_REAL=1 时读这些 key。

OPENAI_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=                 # Grok
DASHSCOPE_API_KEY=           # 阿里 Qwen-VL
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1   # Qwen 端点
ARK_API_KEY=                 # 字节豆包（火山方舟）；model 用 ep-... 或模型名
ARK_BASE_URL=                # 火山方舟端点（如需自定义）
MOONSHOT_API_KEY=            # Kimi（视觉仅 base64）
ZAI_API_KEY=                 # 智谱 GLM-4V/4.6V
LONGCAT_API_KEY=             # 美团 LongCat（实验位，openai 兼容 + api_base）

# 可选：评测并发/预算护栏
BIRDBENCH_MAX_CONCURRENCY=8
BIRDBENCH_SPEND_CAP_USD=

# 前端（birdbench web）
BIRDBENCH_REAL=              # =1 用真机(花钱,读上面 key); 空/0=demo 免费
BIRDBENCH_WEB_PORT=7860      # Gradio 端口
BIRDBENCH_WEB_USER=          # 可选：内部鉴权用户名
BIRDBENCH_WEB_PASS=          # 可选：内部鉴权密码
